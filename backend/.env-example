# LegaLens API env. Copy to .env and fill.
# Local: REDIS_URL optional. Google Cloud Run: add all vars in Cloud Run → Edit & deploy → Variables & secrets.
#
# Frontend ↔ Backend: backend must allow the frontend origin (CORS_ORIGINS). Frontend must call backend (VITE_API_URL).
# See ENV_SETUP.md for the two vars that link frontend and backend.

# --- CORS (required for frontend to call API) ---
# Comma-separated origins. Local dev: localhost:5173. Production: your frontend URL (e.g. https://your-app.web.app).
# Must include the exact origin the browser uses (scheme + host + port).
CORS_ORIGINS=http://localhost:5173

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth0 ---
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://your-api-identifier

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- ElevenLabs ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=
ELEVENLABS_CONVAI_AGENT_ID=your_elevenlabs_convai_agent_id_here
VOICE_AGENT_API_KEY=dev-voice-agent-key

# --- Picovoice ---
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here
PORCUPINE_KEYWORD_PATH=/absolute/path/to/hey-assistant.ppn
# Voice / agents base URLs. Local: localhost:8000. Production (Cloud Run): your API URL (e.g. https://legalens-api-xxxxx-uc.a.run.app/api).
VOICE_TTS_URL=http://localhost:8000/api/voice/tts
VOICE_TURN_URL=http://localhost:8000/api/voice/turn
VOICE_SESSION_ID=
LEGALENS_QA_BASE_URL=http://localhost:8000/api
VOICE_SILENCE_DURATION_SEC=1.2
VOICE_SILENCE_ENERGY_THRESHOLD=0.01
VOICE_MIN_UTTERANCE_SEC=0.3

# --- Backboard ---
BACKBOARD_API_KEY=your_backboard_api_key_here
BACKBOARD_ASSISTANT_ID=your_backboard_assistant_id_here