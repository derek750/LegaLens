# Auth0 (required)
VITE_AUTH0_DOMAIN=x
VITE_AUTH0_CLIENT_ID=x
VITE_AUTH0_AUDIENCE=x
VITE_VOICE_AGENT_API_KEY=dev-voice-agent-key

# API base URL: leave empty for local dev (Vite proxies /api to localhost:8000).
# For production (e.g. Vercel), set to your backend origin, e.g. https://api.yourdomain.com
VITE_API_URL=