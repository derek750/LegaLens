# Auth0 (required)
VITE_AUTH0_DOMAIN=x
VITE_AUTH0_CLIENT_ID=x
VITE_AUTH0_AUDIENCE=x
VITE_VOICE_AGENT_API_KEY=dev-voice-agent-key

# Backend API (required for frontend to call API)
# Local: leave empty (Vite proxies /api to localhost:8000).
# Production: your backend base URL including /api (e.g. https://legalens-api-xxxxx-uc.a.run.app/api).
# Must match the backend’s CORS_ORIGINS (backend allows this origin). See repo ENV_SETUP.md.
VITE_API_URL=